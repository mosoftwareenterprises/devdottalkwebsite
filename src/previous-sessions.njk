---
layout: layout
title: "{dev.talk} - Previous Sessions"
description: "Watch previous sessions from {dev.talk} meetups"
includeBlueskyPosts: true
permalink: previous-sessions.html
sessionScope: "past"   # frontmatter controls which collection to render (past|upcoming|all)
---

{% import "session-info-item.njk" as session %}
<h2 id="previous-sessions">
  <a href="#previous-sessions">Previous sessions</a>
</h2>
<ul>
  {# render sessions from the shared data file based on frontmatter scope #}
  {% set list = sessions[page.sessionScope] or sessions.past %}
  {% for sess in list %}
    {{ session.sessionInfoItem(sess) }}
  {% endfor %}
</ul>
