---
layout: layout
title: "{dev.talk} - Previous Events"
description: "A history of past {dev.talk} meetups, with links to recordings and resources."
includeBlueskyPosts: true
permalink: previous-events.html
eventScope: "past"   # frontmatter controls which collection to render (past|upcoming|all)
---

{% import "event-list-item.njk" as event %}

<section class="previous-events">
  <h1>Previous events</h1>
  <p>The following is a list of our past {dev.talk} meetups. Click the links for details, recordings or photos where available.</p>
  {# Group by year so year headings are semantic and do not jump levels. #}
  {% set list = events[page.eventScope] or events.past %}
  {% set pastSessions = sessions.pastEvents or [] %}
  {% set lastYear = null %}
  {% for ev in list %}
    {%- if ev.year != lastYear %}
      {% if not loop.first %}
        </ul>
      {% endif %}
      <h2>{{ ev.year }}</h2>
      <ul>
      {% set lastYear = ev.year %}
    {%- endif %}
    {{ event.eventItem(ev, pastSessions) }}
    {% if loop.last %}
      </ul>
    {% endif %}
  {% endfor %}
</section>