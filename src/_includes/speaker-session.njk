{% macro speakerSession(sessionId, sessionsList) %}
    {% set sessionRecord = null %}
    {# Try to use the helper function if available #}
    {% if sessions is defined and sessions.findById %}
        {% set sessionRecord = sessions.findById(sessionId) %}
    {% elif sessionsList %}
        {# Fallback to manual search in provided list #}
        {% for session in sessionsList %}
            {% if session.id == sessionId %}
                {% set sessionRecord = session %}
            {% endif %}
        {% endfor %}
    {% endif %}
    {% if not sessionRecord %}
        <p>Session not found.</p>
    {% else %}
        {% set tileImage = sessionRecord.firstSpeakerTileImageLocation %}
        <a href="{{ sessionRecord.firstSpeakerUrl }}" title="{{ sessionRecord.firstSpeakerName }} Linkedin Profile">
            {% if tileImage %}
                <img src="{{ tileImage }}" loading="lazy" class="speaker-headshot" alt="{{ sessionRecord.firstSpeakerName }} Speaker headshot">
            {% endif %}
                <h3>{{ sessionRecord.firstSpeakerName }}</h3>
                {% if sessionRecord.firstSpeakerJobTitle %}
                    <strong>{{ sessionRecord.firstSpeakerJobTitle }}</strong>
                {% endif %}
            </a>
            <h4>{{ sessionRecord.title }}</h4>
            <p class="formatted-description">{{ sessionRecord.description }}</p>
            {% if sessionRecord.firstSpeakerBio %}
                <h5>Speaker Bio</h5>
                <p class="formatted-description">{{ sessionRecord.firstSpeakerBio }}</p>
            {% endif %}
        {% endif %}
    {% endmacro %}