{% if session == nil %}
    <p>Session not found.</p>
{% else %}
    <a href="{{ session.firstSpeakerUrl }}" alt="{{ session.firstSpeakerName }} Linkedin Profile" title="{{ session.firstSpeakerName }} Linkedin Profile">
        <img src="{{ headshotFilename }}" loading="lazy" style="width:100%" alt="{{ session.firstSpeakerName }} Speaker headshot">
        <h3>{{ session.firstSpeakerName }}</h3>
        {% if session.firstSpeakerJobTitle %}
            <strong>{{ session.firstSpeakerJobTitle }}</strong>
        {% endif %}
    </a>
    <h4>{{ session.title }}</h4>
    <p>{{ session.description }}</p>
    {% if session.firstSpeakerBio %}
        <h5>Speaker Bio</h5>
        <p>{{ session.firstSpeakerBio }}</p>
    {% endif %}
{% endif %}