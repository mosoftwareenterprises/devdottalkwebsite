<section>
  <h2 id="upcoming-events">
    <a href="#upcoming-events">Upcoming events</a>
  </h2>
  <ul>
    {# render the future list from the shared data file; the helper routines in src/_data/events.js
       already keep this sorted.
    #}
    {% for ev in events.upcoming %}
      {% set overviewText = (ev.overview or "") | trim %}
      <li class="event-item{% if not overviewText %} event-item--speaker-wanted{% endif %}"{% if ev.id is defined and ev.id %} id="{{ ev.id }}"{% endif %}>
        {# <a href="{{ ev.url }}" target="_blank" rel="noopener noreferrer" class="event-title"> #}
          {% if overviewText %}
            <b>{{ ev.displayDate }}: {{ ev.title }}</b>
          {% else %}
            <b>{{ ev.displayDate }}</b>
          {% endif %}
        {# </a> #}
        {% if overviewText %}
          <p class="event-overview">{{ overviewText }}</p>
        {% else %}
          <span class="event-speaker-wanted-inline">🎤 Speaker wanted: <a href="/call-for-speakers.html">submit a talk idea</a> or <a href="/contact-us.html">get in touch</a>.</span>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</section>