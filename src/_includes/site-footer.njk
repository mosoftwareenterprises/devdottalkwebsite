<footer class="site-footer" role="contentinfo">
  <div class="site-footer-inner">
    <p class="site-footer-lead">Built with Eleventy (11ty), Nunjucks, Markdown, CSS, and JavaScript into a static website.</p>
    <p class="site-footer-meta">Hosted as an Azure Static Web App in Azure. Source code is available on <a class="site-footer-link" href="https://github.com/mosoftwareenterprises/devdottalkwebsite" target="_blank" rel="noopener noreferrer">GitHub</a>.</p>
    <p class="site-footer-meta"><a class="site-footer-link" href="/contact-us.html">Contact Us</a><span class="site-footer-separator">|</span><a class="site-footer-link" href="/faqs.html">FAQs</a><span class="site-footer-separator">|</span><a class="site-footer-link" href="/privacy-policy.html">Privacy Policy</a><span class="site-footer-separator">|</span><a class="site-footer-link" href="/code-of-conduct.html">Code of Conduct</a></p>
    {% set socialLinksClass = "site-footer-social-links" %}
    {% include "social-links.njk" %}
  {% if build and build.commitUrl and build.shortSha %}
    <p class="site-footer-meta">Deployment <a class="site-footer-link" href="{{ build.commitUrl }}" target="_blank" rel="noopener noreferrer">{{ build.shortSha }}</a>{% if build.branch %}<span class="site-footer-separator">|</span>Branch {{ build.branch }}{% endif %}{% if build.builtAtUtc %}<span class="site-footer-separator">|</span>{{ build.builtAtUtc }}{% endif %}</p>
  {% endif %}
    <p class="site-footer-copy">&copy; {{ build.currentYear }} <a class="site-footer-link" href="https://blog.markoliver.website/Bio" target="_blank" rel="noopener noreferrer">Mark Oliver</a>. All rights reserved.</p>
  </div>
</footer>
