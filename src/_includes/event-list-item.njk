{% import "session-info-item.njk" as session %}

{% macro eventItem(ev, sessions) %}
  {% set allSessions = sessions if sessions else [] %}
  {% set eventAnchorId = null %}

  {% if ev.id is defined and ev.id %}
    {% set eventAnchorId = ev.id %}
  {% endif %}

  <li>
    <div class="event-item"{% if eventAnchorId %} id="{{ eventAnchorId }}"{% endif %}>
      <a href="{{ ev.url }}" target="_blank" class="event-title">
        {{ ev.displayDate }}: {{ ev.title }}
      </a>
      {%- if (ev.photoUrl and ev.photoUrl != "TODO") or (ev.videos and ev.videos | length) %}
      <ul class="event-links">
        {%- if ev.photoUrl and ev.photoUrl != "TODO" %}
          <li><a href="{{ ev.photoUrl }}" target="_blank" class="event-link event-link--photos">📸 Photos</a></li>
        {%- endif %}
        {%- for video in ev.videos %}
          {%- if video.url and video.url != "TODO" %}
            <li><a href="{{ video.url }}" target="_blank" class="event-link event-link--video">▶️ {{ video.title }}</a></li>
          {%- endif %}
        {%- endfor %}
      </ul>
      {%- endif %}

      {% set renderedSessionCount = 0 %}
      {% for sess in allSessions %}
        {% if sess.eventID == ev.id %}
          {% if renderedSessionCount == 0 %}
            <h3>Sessions and speakers</h3>
            <ul class="event-sessions">
          {% endif %}
          {{ session.sessionInfoItem(sess) }}
          {% set renderedSessionCount = renderedSessionCount + 1 %}
        {% endif %}
      {% endfor %}
      {% if renderedSessionCount > 0 %}
        </ul>
      {% endif %}
    </div>
  </li>
{% endmacro %}