<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/styles.css?v=1.0.38">
    <link rel="stylesheet" href="/bluesky.css?v=1.0.4">
    <title>{{ title | default("{dev.talk}") }}</title>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <link rel="shortcut icon" href="/favicon.ico"/>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
    <link rel="manifest" href="/site.webmanifest"/>
    <meta name="description" property="og:description" content="{{ description | default("{dev.talk} a FREE monthly meetup for software engineers and related disciplines in the south of the UK run by volunteers within the community.") }}">
    <meta name="title" property="og:title" content="{{ title | default("{dev.talk}") }}">
    <meta property="og:type" content="website">
    <meta name="image" property="og:image" content="/devtalk-wide.jpg">
    <meta name="author" content="{dev.talk}">
  </head>
  <body>
    <script src="/bluesky.js"></script>
    {% if includeBlueskyPosts %}
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          loadBlueskyPosts('devdottalk.uk', 'bluesky-posts', 3);
        });
      </script>
    {% endif %}
    <div class="page-container">
      <main class="main-content">

        <div class="site-header-row">
          {% if hideMainLogo %}
            {% else %}
              <a href="/" class="site-logo-link"><img alt="The devdottalk logo" src="/devtalk-wide.jpg" loading="lazy" class="site-logo"></a>
          {% endif %}
          <div class="site-nav-bar" id="site-nav-bar">
            <button
              type="button"
              class="site-nav-toggle"
              aria-expanded="false"
              aria-controls="primary-nav"
              aria-label="Toggle navigation">
              <span class="site-nav-toggle-icon" aria-hidden="true"></span>
            </button>
            <nav aria-label="Primary" class="site-nav" id="primary-nav">
              <a href="/">Home</a>
              <a href="/attending.html">Attending</a>
              <a href="/call-for-speakers.html">Call for Speakers</a>
              <a href="/speakers.html">Speakers</a>
              <a href="/previous-events.html">Previous Events</a>
              <a href="/previous-sessions.html">Previous Sessions</a>
              <a href="/local-events.html">Local Events</a>
              <a href="/community-projects.html">Community Projects</a>
              <a href="/supporters.html">Supporters</a>
              <a href="/volunteering.html">Volunteering</a>
              <a href="/venues.html">Venues</a>
              <a href="/code-of-conduct.html">Code of Conduct</a>
              <a href="/who-are-we.html">Who Are We?</a>
              <a href="/faqs.html">FAQs</a>
              <a href="/contact-us.html">Contact Us</a>
              <a href="/privacy-policy.html">Privacy Policy</a>
            </nav>
          </div>
        </div>

        {% set eventId = 'evt-JzsilWMHPpTsKHt' %}
        {% include "floating-register-button.njk" %}
    
        {% if hideNextEventBanner %}
          {% else %}
            <section class="next-event-banner">
              <a href="/next-event" class="next-event-banner-link">Next Event Information</a>
            </section>
        {% endif %}
        {{ content | safe }}
        {% include "index/section-buy-us-a-coffee.njk" %}
      </main>
      {% if includeBlueskyPosts %}
        <div
          id="bluesky-posts">
          <!-- Posts will be loaded here -->
          Loading posts...
        </div>
      {% endif %}
    </div>
    {% include "site-footer.njk" %}
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const navBar = document.getElementById('site-nav-bar');
        const navToggle = document.querySelector('.site-nav-toggle');
        const navLinks = document.querySelectorAll('#primary-nav a');
        if (!navBar || !navToggle) {
          return;
        }

        const closeMenu = () => {
          navToggle.setAttribute('aria-expanded', 'false');
          navBar.classList.remove('is-open');
        };

        navToggle.addEventListener('click', () => {
          const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
          navToggle.setAttribute('aria-expanded', String(!isExpanded));
          navBar.classList.toggle('is-open', !isExpanded);
        });

        navLinks.forEach((link) => {
          link.addEventListener('click', () => {
            closeMenu();
          });
        });
      });
    </script>
    <script src='https://storage.ko-fi.com/cdn/scripts/overlay-widget.js'></script>
    <script>
      kofiWidgetOverlay.draw('devdottalk', {
        'type': 'floating-chat',
        'floating-chat.donateButton.text': '',
        'floating-chat.donateButton.background-color': '#c9ced3',
        'floating-chat.donateButton.text-color': '#fff'
      });
    </script>
    <script data-goatcounter="https://devdottalk.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  </body>
</html>