{% macro sessionInfoItem(a, b, c, d, e, f, g) %}
  {#
    The old signature took seven separate parameters:
      title, duration, speakerName, speakerLink, description, videoLink, slidesLink

    To simplify maintenance we now prefer a single "session" object from src/_data/sessions.json.
    However legacy calls still use the old form, so we detect which was supplied
    and normalise to an object named `s`.
  #}

  {% if b is defined %}
    {# old style invocation #}
    {% set s = {
      title: a,
      durationText: b,
      speakerName: c,
      speakerUrl: d,
      description: e,
      videoUrl: f,
      slidesUrl: g
    } %}
  {% else %}
    {# assume first argument is the session object #}
    {% set s = a %}
  {% endif %}

  <li>
    <p>
      <b>
        {% if s.videoUrl and s.videoUrl != "" %}
          <a href="{{ s.videoUrl }}" target="_blank">{{ s.title }}
            ({{ s.durationText }})</a>
        {% else %}
          {{ s.title }}
          ({{ s.durationText }})
        {% endif %}
      </b>
      -
      {# Display up to 2 speakers if present #}
      {% if s.secondSpeakerName and s.secondSpeakerUrl %}
        <a href="{{ s.speakerUrl }}" target="_blank">{{ s.speakerName }}</a>
        &amp; <a href="{{ s.secondSpeakerUrl }}" target="_blank">{{ s.secondSpeakerName }}</a>
      {% else %}
        <a href="{{ s.speakerUrl }}" target="_blank">{{ s.speakerName }}</a>
      {% endif %}
    </p>
    <p>{{ s.description }}</p>
    {% if s.slidesUrl and s.slidesUrl != "" %}
      <p>
        <a href="{{ s.slidesUrl }}" target="_blank">Slides</a>
      </p>
    {% endif %}
  </li>
{% endmacro %}