{% macro sessionInfoItem(session, collapseDescription) %}
  {#
    session        – a session object from src/_data/sessions.json
    collapseDescription (optional boolean) – wrap the description in a <details> element
  #}

  {% set s = session %}
  {% set collapseDescription = collapseDescription == true %}

  {% set hasVideoUrl = s.videoUrl and s.videoUrl != "" and s.videoUrl != "TODO" %}
  {% set titleLower = s.title | trim | lower %}
  {% set isPlaceholderSession = s.title and (titleLower.startsWith("first") or titleLower.startsWith("second")) and titleLower.endsWith("session") %}

  {% if not isPlaceholderSession %}
  <li class="session-info-item">
    <p>
      <b>
        {% if hasVideoUrl %}
          <a href="{{ s.videoUrl }}" target="_blank" rel="noopener noreferrer" class="session-video-link">
            <span class="session-video-link-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="{{ icons.youtube }}"/>
              </svg>
            </span>
            <span>{{ s.title }} ({{ s.durationText }})</span>
          </a>
        {% else %}
          {{ s.title }}
          ({{ s.durationText }})
        {% endif %}
      </b>
      -
      {# Display up to 2 speakers if present #}
      {% if s.secondSpeakerName and s.secondSpeakerUrl %}
        <a href="{{ s.firstSpeakerUrl }}" target="_blank" rel="noopener noreferrer">{{ s.firstSpeakerName }}</a>
        &amp; <a href="{{ s.secondSpeakerUrl }}" target="_blank" rel="noopener noreferrer">{{ s.secondSpeakerName }}</a>
      {% else %}
        <a href="{{ s.firstSpeakerUrl }}" target="_blank" rel="noopener noreferrer">{{ s.firstSpeakerName }}</a>
      {% endif %}
    </p>
    {% if collapseDescription and s.description and s.description != "" %}
      <details>
        <summary>Session description</summary>
        <p class="formatted-description">{{ s.description }}</p>
      </details>
    {% else %}
      <p class="formatted-description">{{ s.description }}</p>
    {% endif %}
    {% if s.slidesUrl and s.slidesUrl != "" %}
      <p>
        <a href="{{ s.slidesUrl }}" target="_blank" rel="noopener noreferrer">Slides</a>
      </p>
    {% endif %}
  </li>
  {% endif %}
{% endmacro %}