{% macro featuredSpeakerPromo(data) -%}
  {% set sessionRecord = data -%}
  {% set resolvedTitle = sessionRecord.title -%}
  {% set resolvedSpeakerName = sessionRecord.firstSpeakerName -%}
  {% set resolvedSpeakerJobTitle = sessionRecord.firstSpeakerJobTitle -%}
  {% set resolvedSpeakerImage = sessionRecord.firstSpeakerBioPicUrl -%}
  {% set resolvedSpeakerUrl = sessionRecord.firstSpeakerUrl -%}
  {% set resolvedDescription = sessionRecord.description -%}
  {% set resolvedSpeakerBio = sessionRecord.firstSpeakerBio -%}
  <article class="featured-speaker-promo">
    <div class="featured-speaker-promo-art">
      <div class="featured-speaker-promo-canvas">
        <div class="featured-speaker-promo-brand">
          <img src="/devtalk-wide.jpg" alt="{dev.talk}" loading="lazy" class="featured-speaker-promo-brand-image"></div>
          <div class="featured-speaker-promo-frame">
            {%- if resolvedSpeakerImage -%}
              <img src="{{ resolvedSpeakerImage }}" alt="{{ resolvedSpeakerName }} headshot" loading="lazy" class="featured-speaker-promo-image">
              {%- else -%}
                <div class="featured-speaker-promo-image featured-speaker-promo-image-placeholder" aria-hidden="true">
                  <span>{{ resolvedSpeakerName }}</span>
                </div>
              {%- endif -%}
            </div>
            <div class="featured-speaker-promo-panel featured-speaker-promo-panel-title">
              <p class="featured-speaker-promo-kicker">{dev.talk} Speaker</p>
              <h3>{{ resolvedTitle }}</h3>
            </div>
            <div class="featured-speaker-promo-panel featured-speaker-promo-panel-meta">
              {%- if events is defined and events.all and sessionRecord.eventID -%}
                {%- for event in events.all -%}
                  {%- if event.id == sessionRecord.eventID -%}
                    <p class="featured-speaker-promo-date">{{ event.displayDate | replace(" 2026", "") | replace(" 2025", "") }}
                      Speaker</p>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if resolvedSpeakerUrl -%}
                <p class="featured-speaker-promo-name">
                  <a href="{{ resolvedSpeakerUrl }}">{{ resolvedSpeakerName }}</a>
                </p>
              {%- else -%}
                <p class="featured-speaker-promo-name">{{ resolvedSpeakerName }}</p>
              {%- endif -%}
              {%- if resolvedSpeakerJobTitle -%}
                <p class="featured-speaker-promo-job">{{ resolvedSpeakerJobTitle }}</p>
              {%- endif -%}
            </div>
          </div>
        </div>
        {%- if resolvedDescription or resolvedSpeakerBio or resolvedSpeakerUrl -%}
          <div class="featured-speaker-promo-body">
            {%- if resolvedDescription -%}
              <p class="featured-speaker-promo-description formatted-description">{{ resolvedDescription }}</p>
            {%- endif -%}
            {%- if resolvedSpeakerBio -%}
              <div class="featured-speaker-promo-bio-block">
                <h4>Speaker Bio</h4>
                <p class="formatted-description">{{ resolvedSpeakerBio }}</p>
              </div>
            {%- endif -%}
            {%- if resolvedSpeakerUrl -%}
              <p class="featured-speaker-promo-actions">
                <a href="{{ resolvedSpeakerUrl }}">View speaker profile</a>
              </p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </article>
    {%- endmacro %}